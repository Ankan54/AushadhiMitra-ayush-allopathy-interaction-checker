# ─────────────────────────────────────────────────────────────────────────────
# AushadhiMitra — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
# Only needed when running outside EC2 (EC2 uses IAM role automatically)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# S3 bucket — account-specific, format: ausadhi-mitra-<account-id>
S3_BUCKET=ausadhi-mitra-<your-account-id>

# ── Bedrock Agents ───────────────────────────────────────────────────────────
# TSTALIASID always routes to the latest DRAFT version of each agent.
# Replace with a named alias ARN for production/stable deployments.
PLANNER_AGENT_ID=JRARFMAC40
PLANNER_AGENT_ALIAS=TSTALIASID

AYUSH_AGENT_ID=0SU1BHJ78L
AYUSH_AGENT_ALIAS=TSTALIASID

ALLOPATHY_AGENT_ID=CNAZG8LA0H
ALLOPATHY_AGENT_ALIAS=TSTALIASID

REASONING_AGENT_ID=03NGZ4CNF3
REASONING_AGENT_ALIAS=TSTALIASID

RESEARCH_AGENT_ID=7DCGAF6N1A
RESEARCH_AGENT_ALIAS=TSTALIASID

# ── PostgreSQL (RDS) ─────────────────────────────────────────────────────────
DB_HOST=<your-rds-endpoint>.rds.amazonaws.com
DB_PORT=5432
DB_NAME=aushadhimitra
DB_USER=<db-username>
DB_PASSWORD=<db-password>
DB_SSL=require

# ── CO-MAS Pipeline Tuning ───────────────────────────────────────────────────
# Maximum plan-research-reason-validate iterations before returning best result
MAX_COMAS_ITERATIONS=3

# Bedrock agent invocation retry settings
AGENT_INVOKE_MAX_RETRIES=2
AGENT_RETRY_BASE_WAIT=3

# Drug name input validation limits (characters)
INPUT_MIN_LENGTH=2
INPUT_MAX_LENGTH=200

# ── Lambda Environment (set automatically by deploy_lambdas.sh) ──────────────
# These are set on the Lambda functions themselves, not the backend container.
# Listed here for reference only.
#
# DYNAMODB_TABLE=ausadhi-imppat
# TAVILY_SECRET_NAME=ausadhi-mitra/tavily-api-key
